# AIOps Bot Configuration

# Database — Docker: sqlite:////app/data/aiops.db | Lokal: sqlite:///./aiops.db
DATABASE_URL=sqlite:////app/data/aiops.db

# KI / Diagnosis
AI_PROVIDER=gemini
GOOGLE_API_KEY=your_gemini_api_key_here
LOCAL_LLM_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=local-model

# IMAP Ingestion
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=test@example.com
IMAP_PASSWORD=secret
IMAP_POLL_INTERVAL=10

# Alerting / Escalation
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=bot@mycompany.com
ON_CALL_EMAIL=oncall@mycompany.com
ON_CALL_PHONE=+49123456789

# Twilio (Modul C)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+123456789
